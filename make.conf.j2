COMMON_FLAGS="-march={{ march }} -O2 -pipe"
CFLAGS="${COMMON_FLAGS}"
CXXFLAGS="${COMMON_FLAGS}"
FCFLAGS="${COMMON_FLAGS}"
FFLAGS="${COMMON_FLAGS}"

CPU_FLAGS_X86="{{ cpu_flags_x86 }}"

PORTDIR="/var/db/repos/gentoo"
DISTDIR="/var/cache/distfiles"
PKGDIR="/var/cache/binpkgs"

FEATURES="buildpkg getbinpkg parallel-fetch parallel-install"

PORTAGE_BINHOST="http://s3.sd.kazer.org/public-artifacts/stage4/{{ hostname }}/binpkgs/"

MAKEOPTS="-j{{ makeopts }}"

USE="bindist -dvd -dvdnav -cdio -ppp"
{%- if 'X' in features %}
# For X
USE="${USE} X dbus gtk png script cairo udev elogind usbredir exif cuda spice tiff jpeg2k jpegxl jpeg opengl"
{%- else %}
# For no X
USE="${USE} -X -cups -wayland"
{%- endif %}
{%- if 'docker' in features %}
# For docker
USE="${USE} containers overlay network"
{%- endif %}
{%- if 'audio' in features %}
# For audio
USE="${USE} alsa bluetooth pulseaudio"
{%- endif %}
{%- if 'wifi' in features %}
# For wifi
USE="${USE} wifi"
{%- endif %}
{%- if 'steam' in features %}
# For steam
USE="${USE} abi_x86_32"
{%- endif %}

# required by libvirt:
USE="${USE} pkcs11 tools"

# PYTHON_TARGETS is an incremental USE_EXPAND var: a bare "python3_13" ADDS
# to the profile default (which still carries python3_12), yielding an
# effective "python3_12 python3_13". Multi-impl python libs then build for
# both, and never match the single-impl binpkgs on the binhost -> ~140
# needless source rebuilds. Clear the profile set with -* so exactly one
# impl is enabled and the binpkgs match.
PYTHON_TARGETS="-* python3_13"
PYTHON_SINGLE_TARGET="python3_13"

# This sets the language of build output to English.
# Please keep this setting intact when reporting bugs.
LC_MESSAGES=C
L10N="en"

VIDEO_CARDS="{{ video_cards }}"

SANE_BACKENDS="{{ sane_backends | default('') }}"

QEMU_SOFTMMU_TARGETS="aarch64 x86_64 arm"

{% if l10n is defined %}
L10N="{{ l10n }}"
{% endif %}
